# Required for NCBI requests
ENTREZ_EMAIL=
ENTREZ_API_KEY=

# Genome note asset paths
DATA_NOTE_GN_ASSETS=
# Legacy alias still supported
DATA_NOTE_SERVER_DATA=
DATA_NOTE_CORRECTIONS_FILE=
# Defaults to ~/gn_assets/cyto_info.tsv.
DATA_NOTE_CYTO_INFO_TSV=
# Defaults to ~/gn_assets/LR_sample_prep.tsv and falls back to the legacy
# ~/genome_note_templates/LR_sample_prep.tsv location if needed.
DATA_NOTE_LR_SAMPLE_PREP_TSV=
DATA_NOTE_AUTHOR_DB=

# Optional debug flags
GN_DEBUG_ENSEMBL=0

# Optional Ensembl endpoint overrides
# Defaults target the current legacy FTP + beta GraphQL setup.
GN_ENSEMBL_GRAPHQL_URL=
GN_ENSEMBL_ORGANISMS_BASE=
GN_ENSEMBL_MAIN_GFF3_BASE=
GN_ENSEMBL_MAIN_GTF_BASE=

# Programme profile (currently darwin)
DATA_NOTE_PROFILE=darwin
DATA_NOTE_INCLUDE_GBIF_DISTRIBUTION=0
DATA_NOTE_INCLUDE_BOLD_BARCODE=0
# public = ENA/NCBI only; public-with-portal = public plus matched TOLQC repair;
# portal = prefer matched TOLQC counts where available.
DATA_NOTE_SEQUENCING_SOURCE=public-with-portal
# read_pairs keeps the existing paired-end Illumina convention; reads reports
# individual reads for paired-end Illumina libraries.
DATA_NOTE_ILLUMINA_COUNT_UNIT=read_pairs

# Optional assembly selection overrides for a single BioProject run
# Use either DATA_NOTE_ASSEMBLY with optional DATA_NOTE_ALT_ASSEMBLY,
# or DATA_NOTE_HAP1_ASSEMBLY with optional DATA_NOTE_HAP2_ASSEMBLY.
DATA_NOTE_ASSEMBLY=
DATA_NOTE_ALT_ASSEMBLY=
DATA_NOTE_HAP1_ASSEMBLY=
DATA_NOTE_HAP2_ASSEMBLY=

# Optional external BOLD barcode workflow path if bold_coi_pipeline is not installed
DATA_NOTE_BOLD_REPO=

# Optional internal ToL portal integration
PORTAL_URL=
PORTAL_API_PATH=/api/v1

# Optional internal JIRA integration
JIRA_BASE_URL=
JIRA_DOMAIN=
# Authoritative pipeline YAMLs are refreshed into this cache for manual checks.
YAML_CACHE_DIR=yaml_cache
# Defaults to the current OS username and host tol22 if left blank.
YAML_SSH_USER=
YAML_SSH_HOST=
YAML_SSH_IDENTITY_FILE=
